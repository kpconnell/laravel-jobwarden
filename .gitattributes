# Keep the distributed package lean — dev/test/CI artifacts are export-ignored
# so `composer require` pulls only what an app needs at runtime.
/.github            export-ignore
/tests              export-ignore
/docs/images        export-ignore
/workbench          export-ignore
/.phpunit.cache     export-ignore
.gitattributes      export-ignore
.gitignore          export-ignore
.dockerignore       export-ignore
docker-compose.yml  export-ignore
phpunit.xml         export-ignore
testbench.yaml      export-ignore
jobwarden-architecture-spec.md export-ignore

# Normalize line endings.
* text=auto eol=lf
*.sh        text eol=lf
jobwarden-host text eol=lf
